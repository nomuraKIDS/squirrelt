
use builtin;
use str;

set edit:completion:arg-completer[squirrelt] = {|@words|
    fn spaces {|n|
        builtin:repeat $n ' ' | str:join ''
    }
    fn cand {|text desc|
        edit:complex-candidate $text &display=$text' '(spaces (- 14 (wcswidth $text)))$desc
    }
    var command = 'squirrelt'
    for word $words[1..-1] {
        if (str:has-prefix $word '-') {
            break
        }
        set command = $command';'$word
    }
    var completions = [
        &'squirrelt'= {
            cand -a '隠しファイルも表示'
            cand --sort-size 'ファイルサイズに基づいてソートし、表示'
            cand -t '最新の更新日順に表示'
            cand --completions 'generate completion files'
            cand -h 'Print help'
            cand --help 'Print help'
        }
    ]
    $completions[$command]
}
